NODE_ENV=production
PORT=3000
DATABASE_URL=file:./prisma/dev.db
EXTERNAL_IP=YOUR_DROPLET_IP

# LiveKit (Self-Hosted WebRTC SFU)
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret123

# TURN Server (Self-Hosted coturn)
TURN_URL=turn:turn:3478?transport=udp
TURN_USERNAME=fukulisane
TURN_PASSWORD=changeme

# RTMP Relay (Self-Hosted nginx-rtmp)
RTMP_URL=rtmp://rtmp:1935/live
HLS_URL=http://rtmp:8080/hls/live

# Social Platform Stream Keys
YOUTUBE_STREAM_KEY=
TIKTOK_STREAM_KEY=
FACEBOOK_STREAM_KEY=
TWITCH_STREAM_KEY=
INSTAGRAM_STREAM_KEY=
LINKEDIN_STREAM_KEY=
